# Sponsor OS — local development secrets.
# Copy to `.env` and fill in. NEVER commit `.env`.
# On Streamlit Community Cloud, put the same keys in App settings → Secrets.
# In GitHub Actions, add them as repository secrets.

# Supabase project (Dashboard → Settings → API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_KEY=YOUR-ANON-PUBLIC-KEY

# Service-role key: ONLY for scripts in jobs/ and GitHub Actions.
# Never used by the Streamlit app. Never share it.
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

# LLM providers (used from Phase 2 onward; free tiers)
GROQ_API_KEY=
GEMINI_API_KEY=
